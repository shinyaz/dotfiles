# =============================================================================
# EditorConfig
# https://editorconfig.org
# =============================================================================

root = true

[*]
indent_style             = space
indent_size              = 2
end_of_line              = lf
charset                  = utf-8
trim_trailing_whitespace = true
insert_final_newline     = true

# =============================================================================
# Language-specific Settings
# =============================================================================

[*.md]
trim_trailing_whitespace = false  # Trailing spaces have meaning in Markdown

[Makefile]
indent_style = tab

[*.go]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[*.py]
indent_size = 4
