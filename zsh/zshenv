# =============================================================================
# Environment (loaded by all zsh processes)
# =============================================================================

# --- XDG Base Directory ---

export XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}
export XDG_CACHE_HOME=${XDG_CACHE_HOME:-$HOME/.cache}
export XDG_DATA_HOME=${XDG_DATA_HOME:-$HOME/.local/share}

# Directory where zsh looks for .zshrc (overrides existing ZDOTDIR setting)
export ZDOTDIR=$XDG_CONFIG_HOME/zsh

# =============================================================================
# PATH
# =============================================================================

# --- Homebrew (macOS: /opt/homebrew, Linux: /home/linuxbrew/.linuxbrew) ---

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# --- Homebrew Python ---

if [[ -d "$HOMEBREW_PREFIX/opt/python/libexec/bin" ]]; then
  export PATH="$HOMEBREW_PREFIX/opt/python/libexec/bin:$PATH"
fi

# Prioritize local tools
export PATH="$HOME/.local/bin:$PATH"

# =============================================================================
# 1Password SSH Agent
# =============================================================================

# Unify socket path to ~/.1password/agent.sock (consistent with ssh/config)
# macOS: Create symbolic link to actual socket
# Linux: Use ~/.1password/agent.sock directly

if [[ "$OSTYPE" == darwin* ]]; then
  _1p_sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  _1p_sign="/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
  if [[ -S "$_1p_sock" ]] && [[ ! -S "$HOME/.1password/agent.sock" ]]; then
    mkdir -p "$HOME/.1password"
    ln -sf "$_1p_sock" "$HOME/.1password/agent.sock"
  fi
else
  _1p_sign="/opt/1Password/op-ssh-sign"
fi

if [[ -S "$HOME/.1password/agent.sock" ]]; then
  export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
fi

# Place op-ssh-sign in ~/.local/bin (referenced by git config gpg.ssh.program)
if [[ -x "$_1p_sign" ]] && [[ ! -L "$HOME/.local/bin/op-ssh-sign" ]]; then
  mkdir -p "$HOME/.local/bin"
  ln -sf "$_1p_sign" "$HOME/.local/bin/op-ssh-sign"
fi

unset _1p_sock _1p_sign

# =============================================================================
# AWS CLI
# =============================================================================

export AWS_CONFIG_FILE="$XDG_CONFIG_HOME/aws/config"
export AWS_SHARED_CREDENTIALS_FILE="$XDG_CONFIG_HOME/aws/credentials"

# =============================================================================
# Claude Code
# =============================================================================

# Configuration to use Claude Code via AWS Bedrock
export CLAUDE_CODE_USE_BEDROCK=1
export AWS_REGION=ap-northeast-1          # Bedrock region

if [[ -f "$HOME/.env.claude" ]]; then
  source "$HOME/.env.claude"
fi
